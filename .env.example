# .env.example — copy to .env and fill in your values
# NEVER commit your real .env to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (used server-side ONLY, never in the Flutter app)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Database (local Docker only) ──────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT (local Docker only) ───────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-token-for-local-dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Payment (Phase 2 — Razorpay) ─────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# ── Node.js WS Server ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
